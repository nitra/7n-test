{
  "name": "mono",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "npm"
  ],
  "type": "module",
  "scripts": {
    "start": "bun ./npm/bin/n.js",
    "test": "vitest run",
    "lint": "bun run lint-ga && bun run lint-js && bun run lint-security && bun run lint-text && bun run lint-image && oxfmt .",
    "lint-ga": "n-cursor lint-ga",
    "lint-js": "bunx oxlint --fix && bunx eslint --fix . && bunx jscpd . && bunx knip --no-config-hints",
    "lint-security": "trufflehog filesystem . --no-update --exclude-paths .trufflehog-exclude --results=verified,unknown --fail",
    "lint-text": "n-cursor lint-text",
    "lint-image": "npx @nitra/minify-image --src=. --write",
    "oxfmt": "oxfmt .",
    "coverage": "n-cursor coverage"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.0",
    "@nitra/cursor": "^12.11.0",
    "@stryker-mutator/vitest-runner": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=25"
  }
}
